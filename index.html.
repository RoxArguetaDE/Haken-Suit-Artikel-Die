<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🗡️ Haken Suit — DIE-Endungen im Deutschen</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;1,400&family=Nunito:wght@400;600;700;800&display=swap');

  :root {
    --rosa: #e91e8c;
    --rosa-claro: #fce4f3;
    --morado: #7b2d8b;
    --dorado: #f0a500;
    --azul: #1a73e8;
    --verde: #0f9d58;
    --rojo: #d93025;
    --gris: #f5f5f5;
    --oscuro: #1a1a2e;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Nunito', sans-serif;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
    min-height: 100vh;
    color: #1a1a2e;
    padding: 20px;
  }

  .container { max-width: 900px; margin: 0 auto; }

  /* HERO */
  .hero {
    text-align: center;
    padding: 40px 20px 30px;
    color: white;
  }
  .hero h1 {
    font-size: 2.8em;
    font-weight: 800;
    text-shadow: 0 0 30px rgba(233,30,140,0.8);
    margin-bottom: 8px;
  }
  .hero .subtitle {
    font-size: 1.1em;
    color: #fce4f3;
    opacity: 0.85;
    margin-bottom: 6px;
  }
  .die-badge {
    display: inline-block;
    background: var(--rosa);
    color: white;
    font-size: 2em;
    font-weight: 800;
    padding: 8px 30px;
    border-radius: 50px;
    margin: 10px 0;
    box-shadow: 0 4px 20px rgba(233,30,140,0.5);
    letter-spacing: 4px;
  }

  /* CARDS */
  .card {
    background: white;
    border-radius: 20px;
    padding: 24px;
    margin-bottom: 20px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
  }

  .card-title {
    font-size: 1.4em;
    font-weight: 800;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  /* STORY */
  .story-card {
    background: linear-gradient(135deg, #fff9f0, #fff0f8);
    border-left: 6px solid var(--rosa);
  }
  .story-text {
    font-family: 'Crimson Text', serif;
    font-size: 1.15em;
    line-height: 1.9;
    color: #333;
  }
  .story-text .ending {
    font-weight: 600;
    color: var(--rosa);
    background: var(--rosa-claro);
    padding: 1px 6px;
    border-radius: 6px;
    font-style: normal;
  }
  .story-text .word-de {
    font-weight: 700;
    color: var(--morado);
  }
  .story-text .word-es {
    color: var(--verde);
    font-style: italic;
  }
  .story-text .word-en {
    color: var(--azul);
    font-style: italic;
  }

  /* ENDINGS TABLE */
  .endings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 14px;
  }

  .ending-block {
    border-radius: 14px;
    padding: 16px;
    border: 2px solid transparent;
    transition: transform 0.2s, box-shadow 0.2s;
    cursor: default;
  }
  .ending-block:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(233,30,140,0.2);
  }

  .ending-tag {
    font-size: 1.6em;
    font-weight: 800;
    color: var(--rosa);
    font-family: 'Crimson Text', serif;
    display: block;
    margin-bottom: 6px;
  }
  .ending-anchor {
    font-size: 0.75em;
    font-weight: 700;
    color: var(--morado);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
    display: block;
  }
  .examples-list {
    list-style: none;
    font-size: 0.82em;
    line-height: 1.7;
  }
  .examples-list li { display: flex; justify-content: space-between; gap: 6px; flex-wrap: wrap; }
  .ex-de { font-weight: 700; color: var(--morado); }
  .ex-es { color: var(--verde); }
  .ex-en { color: var(--azul); }

  /* Color families */
  .c1 { background: #fff0f8; border-color: #f8c8e8; }
  .c2 { background: #f0f4ff; border-color: #c5d4f8; }
  .c3 { background: #f0fff4; border-color: #b8efc8; }
  .c4 { background: #fffaf0; border-color: #fde8b0; }
  .c5 { background: #f5f0ff; border-color: #dcc8f8; }

  /* CATEGORIES */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 14px;
  }
  .cat-block {
    background: var(--gris);
    border-radius: 14px;
    padding: 16px;
    border-top: 4px solid var(--rosa);
  }
  .cat-icon { font-size: 2em; display: block; margin-bottom: 6px; }
  .cat-name { font-weight: 800; font-size: 0.95em; margin-bottom: 8px; color: var(--morado); }
  .cat-note { font-size: 0.78em; color: #666; margin-bottom: 8px; font-style: italic; }
  .cat-examples { font-size: 0.82em; line-height: 1.7; }
  .cat-examples span.de { font-weight: 700; color: var(--rosa); }
  .cat-examples span.tr { color: #555; }

  /* ACCORDION */
  details { margin-bottom: 10px; }
  summary {
    background: var(--rosa-claro);
    border-radius: 10px;
    padding: 12px 16px;
    font-weight: 700;
    cursor: pointer;
    color: var(--morado);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  summary::after { content: '▼'; font-size: 0.8em; }
  details[open] summary::after { content: '▲'; }
  details[open] summary { border-radius: 10px 10px 0 0; }
  .details-content {
    background: white;
    border: 2px solid var(--rosa-claro);
    border-top: none;
    border-radius: 0 0 10px 10px;
    padding: 16px;
    font-size: 0.9em;
    line-height: 1.8;
  }

  /* QUICK REF */
  .quick-ref {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 10px;
  }
  .qr-pill {
    background: var(--rosa);
    color: white;
    padding: 6px 14px;
    border-radius: 50px;
    font-size: 0.85em;
    font-weight: 700;
    letter-spacing: 0.5px;
  }

  /* MERKWORT */
  .acronym-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 8px 0;
    flex-wrap: wrap;
  }
  .acro-letter {
    width: 44px; height: 44px;
    background: var(--rosa);
    color: white;
    font-size: 1.4em;
    font-weight: 800;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .acro-text { flex: 1; min-width: 180px; }
  .acro-ending { font-weight: 700; color: var(--morado); font-size: 1em; }
  .acro-example { font-size: 0.82em; color: #555; }

  section { margin-bottom: 20px; }

  h2.section-title {
    color: white;
    font-size: 1.3em;
    font-weight: 800;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  @media (max-width: 600px) {
    .hero h1 { font-size: 2em; }
    .endings-grid { grid-template-columns: 1fr; }
    .cat-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
</head>
<body>
<div class="container">

  <!-- HERO -->
  <div class="hero">
    <div class="die-badge">DIE</div>
    <h1>🗡️ Haken Suit</h1>
    <p class="subtitle">Die komplette Technik, um den femininen Artikel im Deutschen zu merken</p>
    <p class="subtitle" style="font-size:0.9em; opacity:0.6;">Endungen • Gruppen • Merkgeschichte</p>
  </div>

  <!-- ====== GESCHICHTE ====== -->
  <section>
    <h2 class="section-title">📖 Die Geschichte (laut erzählen)</h2>
    <div class="card story-card">
      <div class="card-title" style="color:var(--morado)">🗡️ Der Samurai und sein Haken Suit</div>
      <p class="story-text">
        Es war einmal ein Samurai namens <span class="word-de">Die</span>, der in einer Burg voller
        <span class="ending">-heit</span> lebte. Seine <span class="word-de">Freiheit</span>
        (<span class="word-es">Unabhängigkeit</span>) war ihm das Wertvollste.
        Er besaß viel <span class="ending">-keit</span> — seine
        <span class="word-de">Freundlichkeit</span> (<span class="word-es">Nettigkeit</span>)
        war im ganzen Königreich berühmt.
        <br><br>
        Jeden Morgen wachte er mit einer <span class="ending">-ung</span> auf: Er plante seine
        perfekte <span class="word-de">Wohnung</span> (<span class="word-es">das Zuhause</span>).
        Er las seine <span class="word-de">Zeitung</span> (<span class="word-es">das Nachrichtenblatt</span>)
        und beglich seine <span class="word-de">Rechnung</span> (<span class="word-es">was man zahlt</span>).
        <br><br>
        Seine <span class="ending">-schaft</span> war legendär: seine
        <span class="word-de">Freundschaft</span> (<span class="word-es">enge Bindung</span>)
        und seine <span class="word-de">Leidenschaft</span> (<span class="word-es">starkes Gefühl</span>)
        ließen ihn tief schlafen (<em>Schaft = schlafen</em> 💤).
        <br><br>
        Eines Tages kam der Samurai zur <span class="ending">-tät</span>: seine
        <span class="word-de">Universität</span> (<span class="word-es">Hochschule</span>),
        wo er mit großer <span class="word-de">Qualität</span> (<span class="word-es">Güte</span>) studierte.
        Dort gab es viel <span class="ending">-tion</span> / <span class="ending">-sion</span>:
        die <span class="word-de">Information</span>, die <span class="word-de">Nation</span>,
        die <span class="word-de">Version</span>, die <span class="word-de">Passion</span>.
        <br><br>
        Mit <span class="ending">-anz</span> und <span class="ending">-enz</span> schmückte er seinen Anzug:
        die <span class="word-de">Eleganz</span> (<span class="word-es">Vornehmheit</span>),
        die <span class="word-de">Toleranz</span> (<span class="word-es">Duldsamkeit</span>),
        die <span class="word-de">Existenz</span> (<span class="word-es">das Dasein</span>).
        <br><br>
        In der <span class="ending">-ei</span> des Dorfes (einer <span class="word-de">Bäckerei</span> 🥐 =
        <span class="word-es">wo man Brot kauft</span>) kaufte er Brot.
        Dann ging er in die <span class="word-de">Metzgerei</span> (<span class="word-es">Fleischladen</span>)
        und in die <span class="word-de">Bücherei</span> (<span class="word-es">Bibliothek</span>).
        <br><br>
        Seine Lehrerin, die <span class="ending">-in</span> — die
        <span class="word-de">Lehrerin</span> (<span class="word-es">weibliche Lehrkraft</span>) —
        lehrte ihn die <span class="ending">-ik</span>:
        die <span class="word-de">Musik</span> 🎵 (<span class="word-es">Töne</span>),
        die <span class="word-de">Physik</span> (<span class="word-es">Naturwissenschaft</span>),
        die <span class="word-de">Mathematik</span> (<span class="word-es">Zahlenlehre</span>).
        <br><br>
        Der Samurai spielte seine <span class="ending">-ur</span>:
        die <span class="word-de">Gitarre</span> gehörte zur
        <span class="word-de">Natur</span> (<span class="word-es">Umwelt</span>),
        zur <span class="word-de">Kultur</span> (<span class="word-es">Traditionen</span>),
        zur <span class="word-de">Frisur</span> (<span class="word-es">Haarform</span>).
        <br><br>
        Er nutzte eine <span class="ending">-ive</span> — eine
        <span class="word-de">Alternative</span> (<span class="word-es">andere Option</span>)
        und <span class="word-de">Initiative</span> (<span class="word-es">erster Schritt</span>) —,
        um seinen Anzug in der <span class="ending">-age</span> zu verstauen:
        die <span class="word-de">Garage</span> 🚗 (<span class="word-es">fürs Auto</span>),
        die <span class="word-de">Massage</span> (<span class="word-es">Behandlung</span>).
        <br><br>
        Zum Nachtisch nahm er eine <span class="ending">-ade</span>:
        die <span class="word-de">Limonade</span> 🍋 (<span class="word-es">süßes Getränk</span>)
        und die <span class="word-de">Marmelade</span> (<span class="word-es">Brotaufstrich</span>).
        <br><br>
        Schließlich träumte er mit <span class="ending">-ie</span> von der
        <span class="word-de">Energie</span> ⚡ (<span class="word-es">Kraft</span>),
        der <span class="word-de">Demokratie</span> (<span class="word-es">Volksherrschaft</span>)
        und der <span class="word-de">Philosophie</span> (<span class="word-es">Denklehre</span>).
        <br><br>
        Und seine Ukulele 🎸 — <span class="ending">-e am Ende</span> —
        war seine <span class="word-de">Maschine</span> (<span class="word-es">das Gerät</span>),
        die <span class="word-de">Küche</span> (<span class="word-es">Kochraum</span>),
        die <span class="word-de">Brücke</span> (<span class="word-es">Übergang</span>).
        <br><br>
        <strong>ENDE! Der Samurai Die schlief mit seinem Haken Suit ein. 🗡️💤</strong>
      </p>
    </div>
  </section>

  <!-- ====== MERKWORT ====== -->
  <section>
    <h2 class="section-title">🔑 Merkwort: „HUKE-TASTI“</h2>
    <div class="card">
      <p style="margin-bottom:14px; color:#555; font-size:0.9em;">Merke dir alle Endungen mit diesem erfundenen Wort:</p>
      <div class="acronym-row"><div class="acro-letter">H</div><div class="acro-text"><span class="acro-ending">-HEIT / -KEIT</span><br><span class="acro-example">Freiheit · Freundlichkeit</span></div></div>
      <div class="acronym-row"><div class="acro-letter">U</div><div class="acro-text"><span class="acro-ending">-UNG</span><br><span class="acro-example">Wohnung · Zeitung</span></div></div>
      <div class="acronym-row"><div class="acro-letter">K</div><div class="acro-text"><span class="acro-ending">-KEIT (Erinnerung) + -IK</span><br><span class="acro-example">Musik · Physik</span></div></div>
      <div class="acronym-row"><div class="acro-letter">E</div><div class="acro-text"><span class="acro-ending">-EI / -ERIE / -ENZ / -E (viele)</span><br><span class="acro-example">Bäckerei · Existenz · Brücke</span></div></div>
      <div class="acronym-row"><div class="acro-letter">T</div><div class="acro-text"><span class="acro-ending">-TÄT / -TION / -TANZ</span><br><span class="acro-example">Universität · Information · Toleranz</span></div></div>
      <div class="acronym-row"><div class="acro-letter">A</div><div class="acro-text"><span class="acro-ending">-ANZ / -AGE / -ADE</span><br><span class="acro-example">Eleganz · Garage · Limonade</span></div></div>
      <div class="acronym-row"><div class="acro-letter">S</div><div class="acro-text"><span class="acro-ending">-SCHAFT</span><br><span class="acro-example">Freundschaft · Gesellschaft</span></div></div>
      <div class="acronym-row"><div class="acro-letter">T</div><div class="acro-text"><span class="acro-ending">-TAT / -TUR / -TIVE / -TION</span><br><span class="acro-example">Natur · Alternative · Initiative</span></div></div>
      <div class="acronym-row"><div class="acro-letter">I</div><div class="acro-text"><span class="acro-ending">-IE / -IN / -ISSE / -INE / -IVE / -IK</span><br><span class="acro-example">Energie · Lehrerin · Maschine</span></div></div>
    </div>
  </section>

  <!-- ====== ENDUNGEN ====== -->
  <section>
    <h2 class="section-title">📌 Alle Endungen mit Beispielen</h2>
    <div class="endings-grid">

      <div class="ending-block c1">
        <span class="ending-tag">-heit</span>
        <span class="ending-anchor">💡 Eselsbrücke: klingt wie span. „caliente“</span>
        <ul class="examples-list">
          <li><span class="ex-de">Freiheit</span><span class="ex-es">Unabhängigkeit</span></li>
          <li><span class="ex-de">Schönheit</span><span class="ex-es">Attraktivität</span></li>
          <li><span class="ex-de">Gesundheit</span><span class="ex-es">Wohlbefinden</span></li>
          <li><span class="ex-de">Wahrheit</span><span class="ex-es">das Wahre</span></li>
          <li><span class="ex-de">Dummheit</span><span class="ex-es">Torheit</span></li>
        </ul>
      </div>

      <div class="ending-block c2">
        <span class="ending-tag">-keit</span>
        <span class="ending-anchor">💡 Eselsbrücke: span. „gato“ → keit</span>
        <ul class="examples-list">
          <li><span class="ex-de">Freundlichkeit</span><span class="ex-es">Nettigkeit</span></li>
          <li><span class="ex-de">Möglichkeit</span><span class="ex-es">Chance</span></li>
          <li><span class="ex-de">Wirklichkeit</span><span class="ex-es">Realität</span></li>
          <li><span class="ex-de">Einigkeit</span><span class="ex-es">Eintracht</span></li>
          <li><span class="ex-de">Flüssigkeit</span><span class="ex-es">z. B. Wasser</span></li>
        </ul>
      </div>

      <div class="ending-block c3">
        <span class="ending-tag">-ung</span>
        <span class="ending-anchor">💡 sehr häufig — fast immer DIE!</span>
        <ul class="examples-list">
          <li><span class="ex-de">Wohnung</span><span class="ex-es">das Zuhause</span></li>
          <li><span class="ex-de">Zeitung</span><span class="ex-es">Nachrichtenblatt</span></li>
          <li><span class="ex-de">Lösung</span><span class="ex-es">Antwort auf ein Problem</span></li>
          <li><span class="ex-de">Rechnung</span><span class="ex-es">was man zahlt</span></li>
          <li><span class="ex-de">Übung</span><span class="ex-es">Training</span></li>
        </ul>
      </div>

      <div class="ending-block c4">
        <span class="ending-tag">-schaft</span>
        <span class="ending-anchor">💡 Merke: Schaft = schlafen (aus der Geschichte)</span>
        <ul class="examples-list">
          <li><span class="ex-de">Freundschaft</span><span class="ex-es">enge Bindung</span></li>
          <li><span class="ex-de">Gesellschaft</span><span class="ex-es">Gemeinschaft</span></li>
          <li><span class="ex-de">Leidenschaft</span><span class="ex-es">starkes Gefühl</span></li>
          <li><span class="ex-de">Botschaft</span><span class="ex-es">Nachricht</span></li>
          <li><span class="ex-de">Mannschaft</span><span class="ex-es">Team</span></li>
        </ul>
      </div>

      <div class="ending-block c5">
        <span class="ending-tag">-tät</span>
        <span class="ending-anchor">💡 = span. „-dad“ / engl. „-ty“</span>
        <ul class="examples-list">
          <li><span class="ex-de">Universität</span><span class="ex-es">Hochschule</span></li>
          <li><span class="ex-de">Qualität</span><span class="ex-es">Güte</span></li>
          <li><span class="ex-de">Realität</span><span class="ex-es">Wirklichkeit</span></li>
          <li><span class="ex-de">Nationalität</span><span class="ex-es">Staatsangehörigkeit</span></li>
          <li><span class="ex-de">Kapazität</span><span class="ex-es">Fassungsvermögen</span></li>
        </ul>
      </div>

      <div class="ending-block c1">
        <span class="ending-tag">-tion / -sion</span>
        <span class="ending-anchor">💡 = span. „-ción“ / engl. „-tion“</span>
        <ul class="examples-list">
          <li><span class="ex-de">Information</span><span class="ex-es">Auskunft</span></li>
          <li><span class="ex-de">Nation</span><span class="ex-es">Land / Volk</span></li>
          <li><span class="ex-de">Version</span><span class="ex-es">Fassung</span></li>
          <li><span class="ex-de">Passion</span><span class="ex-es">Leidenschaft</span></li>
          <li><span class="ex-de">Situation</span><span class="ex-es">Lage</span></li>
        </ul>
      </div>

      <div class="ending-block c2">
        <span class="ending-tag">-anz / -enz</span>
        <span class="ending-anchor">💡 = span. „-ancia / -encia“</span>
        <ul class="examples-list">
          <li><span class="ex-de">Eleganz</span><span class="ex-es">Vornehmheit</span></li>
          <li><span class="ex-de">Toleranz</span><span class="ex-es">Duldsamkeit</span></li>
          <li><span class="ex-de">Existenz</span><span class="ex-es">Dasein</span></li>
          <li><span class="ex-de">Differenz</span><span class="ex-es">Unterschied</span></li>
          <li><span class="ex-de">Distanz</span><span class="ex-es">Abstand</span></li>
        </ul>
      </div>

      <div class="ending-block c3">
        <span class="ending-tag">-ei</span>
        <span class="ending-anchor">💡 Läden & Orte der Herstellung</span>
        <ul class="examples-list">
          <li><span class="ex-de">Bäckerei</span><span class="ex-es">wo man Brot kauft</span></li>
          <li><span class="ex-de">Metzgerei</span><span class="ex-es">Fleischladen</span></li>
          <li><span class="ex-de">Bücherei</span><span class="ex-es">Bibliothek</span></li>
          <li><span class="ex-de">Partei</span><span class="ex-es">politische Gruppe</span></li>
          <li><span class="ex-de">Türkei</span><span class="ex-es">Land (Ankara)</span></li>
        </ul>
      </div>

      <div class="ending-block c4">
        <span class="ending-tag">-in</span>
        <span class="ending-anchor">💡 weibliche Form von Berufen/Personen</span>
        <ul class="examples-list">
          <li><span class="ex-de">Lehrerin</span><span class="ex-es">weibliche Lehrkraft</span></li>
